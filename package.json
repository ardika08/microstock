{
  "name": "adobestock-autofill",
  "displayName": "Autofillstock",
  "version": "0.1.0",
  "description": "Chrome extension for generating and auto-filling microstock metadata with Autofillstock.",
  "author": "Autofillstock",
  "scripts": {
    "dev": "plasmo dev",
    "backend:dev": "next dev -p 3000",
    "backend:build": "next build",
    "backend:start": "next start -p 3000",
    "activation:create": "tsx scripts/create-activation-code.ts",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.5",
    "@plasmohq/messaging": "^0.7.1",
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "next-auth": "^4.24.14",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^19.2.7",
    "recharts": "^3.9.2",
    "tailwind-merge": "^2.5.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^11.7.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.38.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "manifest": {
    "key": "",
    "permissions": [
      "activeTab",
      "notifications",
      "scripting",
      "storage"
    ],
    "host_permissions": [
      "https://contributor.stock.adobe.com/*",
      "https://stock.adobe.com/*",
      "https://submit.shutterstock.com/*",
      "https://contributor-accounts.shutterstock.com/*",
      "https://api.openai.com/*",
      "https://autofillstock.my.id/*"
    ]
  }
}
