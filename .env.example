# URL endpoint aktivasi — WAJIB diisi dengan URL production sebelum build
# Jangan biarkan nilai localhost saat build production!
# Contoh production: https://api.yourdomain.com/api/activate
PLASMO_PUBLIC_ACTIVATION_API_URL=https://your-activation-server.com/api/activate

# Path ke SQLite database di server
ACTIVATION_DB_PATH=./data/activation.sqlite

# CORS origin — WAJIB diisi dengan chrome-extension://<extension-id> di production
# Jangan gunakan wildcard "*" di production!
# Cara cari extension ID: chrome://extensions -> Developer mode -> ID extension
ACTIVATION_ALLOWED_ORIGIN=chrome-extension://REPLACE_WITH_YOUR_EXTENSION_ID
